{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/club", "destination": "/comunidad", "permanent": false }
  ],
  "functions": {
    "api/whatsapp.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron", "schedule": "0 12 * * *" }
  ],
  "headers": [
    {
      "source": "/WHAPE.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"WHAPE.apk\"" }
      ]
    }
  ]
}
